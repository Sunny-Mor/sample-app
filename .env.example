AWS_REGION=us-east-1

# DynamoDB
DYNAMODB_TABLE=users_table

# RDS PostgreSQL
POSTGRES_HOST=sample-app-db.xxxxxx.us-east-1.rds.amazonaws.com
POSTGRES_DB=appdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=YourPassword123!
POSTGRES_PORT=5432

# ElastiCache Redis
REDIS_HOST=sample-app-redis.xxxxxx.cache.amazonaws.com
REDIS_PORT=6379

# S3
S3_BUCKET=sample-app-files-123456789012

# SNS
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:app-notifications

# SES
SES_FROM_EMAIL=noreply@yourdomain.com
